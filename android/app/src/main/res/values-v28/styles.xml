<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        API 28+: allow content to extend into display cutout areas.
        shortEdges = content can go into cutout on short edges (top/bottom).
        Required for Galaxy S/A series punch-hole cameras so the status
        bar area isn't wasted black space.
    -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">#07070F</item>
        <item name="android:navigationBarColor">#07070F</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

</resources>
