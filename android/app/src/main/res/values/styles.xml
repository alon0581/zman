<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!--
        App theme: no action bar, dark status/nav bars matching the app background color.
        Using solid #07070F (same as the bg CSS variable) so bars look seamless.
        No transparent/edge-to-edge needed, no WebView inset issues.
    -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Match app background — looks seamless, no edge-to-edge needed -->
        <item name="android:statusBarColor">#07070F</item>
        <item name="android:navigationBarColor">#07070F</item>

        <!-- White icons in status bar (app has dark background) -->
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
    </style>

</resources>
